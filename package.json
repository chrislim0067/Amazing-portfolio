{
  "name": "igloo-inc",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-svelte-runtime.js && node scripts/patch-copy.js",
    "patch:copy": "node scripts/patch-copy.js",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start:reference": "node scripts/serve-reference.mjs",
    "start:legacy": "npx --yes serve . -p 3000",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
